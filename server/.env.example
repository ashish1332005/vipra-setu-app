NODE_ENV=production
PORT=5000
# Production/Render needs a real Atlas URI. Local development can use mongodb://127.0.0.1:27017/vipra-setu only if MongoDB is running.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/vipra-setu
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

CLIENT_URL=https://your-client-domain.com
CLIENT_URLS=https://your-client-domain.com,http://localhost:5173

EMAIL_FROM="Vipra Sewa Setu <no-reply@yourdomain.com>"

# Optional only when email verification/transactional email is enabled.
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
